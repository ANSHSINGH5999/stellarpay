# StellarPay Environment Variables
# Copy this file to .env.local and fill in values

# Stellar Network (testnet for development, public for production)
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org

# App URL (set to your Vercel URL in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Static XLM/INR rate (override with live feed in production)
NEXT_PUBLIC_XLM_TO_INR=10.5

# Google Form ID (from your feedback form — see README)
NEXT_PUBLIC_FEEDBACK_FORM_ID=

# Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
